# ──────────────────────────────────────────
# Expense Tracker Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env file.
# ──────────────────────────────────────────

# Database (Neon PostgreSQL)
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Server
PORT=5001
# development | production. In production the rate limits tighten and CORS '*' is rejected.
NODE_ENV=development

# Number of reverse proxies in front of the app (e.g. 1 behind Nginx/a PaaS load
# balancer). Controls how Express derives the client IP for rate limiting.
# Leave unset / false for direct connections in local dev. Never set to 'true'
# in production behind an untrusted network — it re-enables IP spoofing.
TRUST_PROXY=false

# Authentication
# JWT_SECRET must be at least 32 characters — the server refuses to start otherwise.
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars
# Access-token lifetime (short). Refresh-token lifetime (long).
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# CORS — comma-separated list of allowed origins
# Set to your frontend/mobile dev host in development
# Use specific origins in production (never * in production)
CORS_ORIGIN=http://localhost:8081,http://10.0.2.2:8081

# ── Email ─────────────────────────────────────────────────────────────────
# Transport is chosen by whichever credentials are set (see config/mailer.ts):
#
#   GMAIL_REFRESH_TOKEN → Gmail API over HTTPS   (recommended for production)
#   BREVO_API_KEY       → Brevo API over HTTPS   (alternative)
#   neither             → direct SMTP            (local dev)
#
# Why not SMTP in production: cloud hosts (Railway, Render, …) block outbound
# SMTP ports, so nodemailer just times out there.

# ── Option A: Gmail API (recommended — no custom domain needed) ──
# Mail is sent by Google as your own Gmail account, so SPF/DKIM/DMARC align and
# it lands in the inbox. An ESP without an authenticated domain sends from its
# SHARED domain, which Gmail rate-limits (421 4.7.28).
# Setup: Google Cloud → enable Gmail API → OAuth consent screen (PUBLISH it, or
# refresh tokens expire after 7 days) → Credentials → OAuth client (Desktop app).
# Then run:  GMAIL_CLIENT_ID=... GMAIL_CLIENT_SECRET=... npx tsx scripts/gmail-oauth.ts
# SMTP_FROM must be the same Gmail account. Limit: ~500 emails/day.
# GMAIL_CLIENT_ID=...apps.googleusercontent.com
# GMAIL_CLIENT_SECRET=GOCSPX-...
# GMAIL_REFRESH_TOKEN=1//0g...

# ── Option B: Brevo HTTPS API ──
# Get a key: Brevo → SMTP & API → API Keys (an "API key" xkeysib-..., NOT the
# SMTP key). SMTP_FROM must be a VERIFIED SENDER in Brevo (Senders, Domains &
# Dedicated IPs → Senders). Without an authenticated custom domain, expect
# spam-foldering / Gmail rate limits.
# BREVO_API_KEY=xkeysib-...

# SMTP (local-dev fallback; unused when GMAIL_REFRESH_TOKEN or BREVO_API_KEY is set)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
# Also the sender for the Gmail API / Brevo paths above:
#  - Gmail API: must be the SAME Gmail account you authorised
#  - Brevo:     must be a verified sender there
SMTP_FROM=PulseSpend <your-email@gmail.com>
# Inbox that receives "Report a Problem" / feedback emails (defaults to SMTP_USER).
SUPPORT_EMAIL=support@yourdomain.com

# Cloudinary (profile photo / receipt uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Upstash Redis (rate limiting)
UPSTASH_REDIS_REST_URL=https://your-region.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Firebase Admin SDK (push notifications)
# Full setup walkthrough: see SETUP_PUSH.md in the repo root.
# Option A: JSON string (recommended for cloud deployment)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
#
# Option B: Path to service account JSON file (local dev only)
# GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json
# NOTE: Never commit the service account JSON file to git!

# Exchange Rate API (for multi-currency conversion)
EXCHANGE_RATE_API_KEY=your-exchangerate-api-key
